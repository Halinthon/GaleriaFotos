<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="4dp">
    <ImageView android:id="@+id/ivCover"
        android:layout_width="match_parent" android:layout_height="160dp"
        android:scaleType="centerCrop" android:background="#1a1a1a"/>
    <TextView android:id="@+id/tvName"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textStyle="bold" android:textSize="13sp" android:padding="4dp"
        android:maxLines="1" android:ellipsize="end"/>
    <TextView android:id="@+id/tvCount"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="#888888" android:paddingStart="4dp"
        android:paddingBottom="4dp"/>
</LinearLayout>
